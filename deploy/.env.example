# Copy to deploy/.env and fill in real values before running:
#   docker compose --env-file deploy/.env -f deploy/langfuse-compose.yml up -d
#
# Generate strong secrets with:
#   openssl rand -hex 32
#
# Never commit the resolved deploy/.env file.

# Postgres credentials for the Langfuse metadata DB
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=replace-with-openssl-rand-hex-32
LANGFUSE_DB_NAME=langfuse

# Langfuse application secrets (each independently generated)
LANGFUSE_NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
LANGFUSE_SALT=replace-with-openssl-rand-hex-32
